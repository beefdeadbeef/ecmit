clang
--target=arm-none-eabi
-mcpu=cortex-m4
-isystem/usr/libexec/arm-none-eabi/include
-Ilibopencm3/include
-Ilibopencm3/tests/shared
-Imk/bgrt
-Ibgrt/kernel
-Ibgrt/kernel/default
-Ibgrt/arch/cm4f/gcc
-Ibgrt/libs/native
-Ilwip/src/include
-Imk/lwip/bgrt/include
-DAT32F43X
-DUSB_OTG_FS_BASE=USB_OTG_FS1_BASE
-DRCC_OTGFS=RCC_OTGFS1
